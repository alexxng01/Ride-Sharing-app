# ─────────────────────────────────────────────────────────────
# NamloRides – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Demo login credentials ─────────────────────────────────────
# Single hardcoded test account. Both must be set or login fails.
REACT_APP_DEMO_USERNAME=intern@namlotech.com
REACT_APP_DEMO_PASSWORD=namlo2026

# ── Firebase Realtime Database ─────────────────────────────────
# 1. Create a project at https://console.firebase.google.com
# 2. Go to Project Settings → General → Your apps → Web app
# 3. Copy the firebaseConfig values below
# 4. Enable Realtime Database (Build → Realtime Database → Create database)
# 5. Set rules to allow public access for demo:
#    { "rules": { ".read": true, ".write": true } }

REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# ── MockAPI.io REST Endpoint ────────────────────────────────────
# 1. Sign up at https://mockapi.io (free)
# 2. Create a new project
# 3. Add a "rides" resource with these string fields:
#    rideId, riderId, riderName, driverName, vehicleType, plate,
#    pickup, dropoff, status, fare, distance, duration, createdAt, completedAt
# 4. Copy your base URL (without /rides) below

REACT_APP_MOCKAPI_URL=https://YOUR_ID.mockapi.io/api/v1

# ── OpenWeather (optional) ─────────────────────────────────────
# Used only for the traffic overlay toggle on the map.
# Sign up at https://openweathermap.org/ (free tier) and copy your API key.
# Leave blank to hide the traffic toggle entirely.
REACT_APP_OPENWEATHER_API_KEY=
