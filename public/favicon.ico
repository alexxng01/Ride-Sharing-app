  <!-- Windows -->
  <rect x="26" y="15" width="5" height="7" rx="1.5" fill="#0F172A" opacity="0.5"/>
  <rect x="33" y="15" width="5" height="7" rx="1.5" fill="#0F172A" opacity="0.5"/>

  <!-- Wheels -->
  <circle cx="25" cy="31" r="3.5" fill="#FACC15"/>
  <circle cx="25" cy="31" r="1.8" fill="#0F172A"/>
  <circle cx="39" cy="31" r="3.5" fill="#FACC15"/>
